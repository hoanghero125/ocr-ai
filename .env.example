# ── Required ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here

# ── AWS (mocked locally via moto — keep these as-is for local dev) ─────────────
AWS_REGION=us-east-1
DYNAMODB_TABLE=local-jobs
S3_BUCKET=local-results
OCR_JOB_QUEUE_URL=http://localhost/local-queue   # unused locally — worker invoked directly
ENVIRONMENT=local

# ── Mistral model settings (defaults are fine) ────────────────────────────────
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_TABLE_FORMAT=html
MISTRAL_TIMEOUT_S=120
MISTRAL_MAX_RETRIES=4

# ── Rate limiter (disabled locally — empty string = no DynamoDB rate limit) ────
MISTRAL_RATE_LIMIT_TABLE=

# ── Processing ─────────────────────────────────────────────────────────────────
MAX_CONCURRENT_PAGES=4
LAMBDA_EXTRACT_CONTINUATION_ENABLED=false   # no Lambda timeouts locally
EXTRACT_MAX_RETRIES_PER_PAGE=2
MAX_CONTINUATIONS=5
WEBHOOK_TIMEOUT_S=10
WEBHOOK_MAX_RETRIES=3
