# ── Required ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here

# ── AWS credentials (for DynamoDB + SQS) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-southeast-1

# ── DynamoDB ───────────────────────────────────────────────────────────────────
DYNAMODB_TABLE=ocr_jobs

# ── SQS ────────────────────────────────────────────────────────────────────────
OCR_JOB_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/<account-id>/<queue-name>

# ── MinIO (object storage for results and checkpoints) ────────────────────────
MINIO_URL=https://minioapi.digeni.vn
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=mistral-ai

# ── Public API base URL (used in status_url field of job responses) ────────────
HTTP_API_BASE_URL=https://ocr-ai.digeni.vn

# ── Worker Lambda function name (for continuation self-invocation) ─────────────
WORKER_FUNCTION_NAME=bizgenie-ocr-staging-worker

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=local

# ── Mistral model settings (defaults are fine) ────────────────────────────────
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_TABLE_FORMAT=html
MISTRAL_TIMEOUT_S=120
MISTRAL_MAX_RETRIES=4

# ── Rate limiter (disabled locally — empty string = no DynamoDB rate limit) ────
MISTRAL_RATE_LIMIT_TABLE=

# ── Processing ─────────────────────────────────────────────────────────────────
MAX_CONCURRENT_PAGES=4
LAMBDA_EXTRACT_CONTINUATION_ENABLED=false
EXTRACT_MAX_RETRIES_PER_PAGE=2
MAX_CONTINUATIONS=5
WEBHOOK_TIMEOUT_S=10
WEBHOOK_MAX_RETRIES=3
